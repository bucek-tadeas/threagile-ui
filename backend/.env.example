# Threagile UI Backend Configuration
# Copy this file to .env and update with your values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Control the host, port, and CORS origins for the backend server

# Host to bind the backend server to
HOST=0.0.0.0

# Port to run the backend server on
PORT=8000

# Comma-separated list of allowed CORS origins
# Update this if the frontend runs on a different host/port
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Frontend URL - used for OAuth redirect after GitHub authentication
FRONTEND_URL=http://localhost:5173


# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Control which execution methods are available and which env vars are required

# Enable local storage execution (requires ALLOWED_PATHS)
USING_LOCAL_STORAGE=true

# Enable GitHub integration (requires GITHUB_* variables)
USING_GITHUB=true


# ============================================================================
# EXECUTION CONTROL
# ============================================================================
# Control whether each execution method is enabled in the backend

# Enable local execution (if USING_LOCAL_STORAGE=true)
STORE_LOCAL_ENABLED=true

# Enable GitHub execution (if USING_GITHUB=true)
STORE_GITHUB_ENABLED=true


# ============================================================================
# LOCAL STORAGE CONFIGURATION (required if USING_LOCAL_STORAGE=true)
# ============================================================================

# Comma-separated list of allowed base paths for threat model storage
ALLOWED_PATHS=/path/to/models,/another/path/to/models

# Directory where threagile will execute
THREAGILE_DIRECTORY=/path/to/threagile/data


# ============================================================================
# GITHUB OAUTH CONFIGURATION (required if USING_GITHUB=true)
# ============================================================================

# GitHub OAuth App credentials
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# OAuth callback URL (must match GitHub App settings)
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# GitHub organization API URL for repos
# For organizations: https://api.github.com/orgs/your-org-name
# For personal accounts: https://api.github.com/users/your-username
GITHUB_ORG_URI=https://api.github.com/orgs/your-org-name


# ============================================================================
# SESSION AND SECURITY CONFIGURATION
# ============================================================================

# Session time-to-live in seconds (default: 43200 = 12 hours)
SESSION_TTL_SECONDS=43200

# Session store type: "memory" (default, dev) or "file" (persistent, production)
SESSION_STORE=memory

# Path to session JSON file (only used when SESSION_STORE=file)
SESSION_FILE_PATH=sessions.json

# Set to 'true' for production HTTPS deployments
# Leave 'false' for localhost development
COOKIE_SECURE=false

# Cookie SameSite attribute: 'lax', 'strict', or 'none'
# 'lax' is recommended for most cases
# Use 'none' with COOKIE_SECURE=true for cross-site scenarios
COOKIE_SAMESITE=lax


# ============================================================================
# EXAMPLE CONFIGURATIONS
# ============================================================================

# --- Development (All Features) ---
# HOST=0.0.0.0
# PORT=8000
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# USING_LOCAL_STORAGE=true
# USING_GITHUB=true
# STORE_LOCAL_ENABLED=true
# STORE_GITHUB_ENABLED=true
# ALLOWED_PATHS=/home/user/threat-models
# GITHUB_CLIENT_ID=dev_client_id
# GITHUB_CLIENT_SECRET=dev_client_secret
# GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback
# GITHUB_ORG_URI=https://api.github.com/orgs/dev-org
# THREAGILE_DIRECTORY=/home/user/threagile
# SESSION_TTL_SECONDS=43200
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax

# --- Production (HTTPS, All Features) ---
# HOST=0.0.0.0
# PORT=8000
# CORS_ORIGINS=https://threagile.example.com
# USING_LOCAL_STORAGE=true
# USING_GITHUB=true
# STORE_LOCAL_ENABLED=true
# STORE_GITHUB_ENABLED=true
# ALLOWED_PATHS=/var/lib/threat-models
# GITHUB_CLIENT_ID=prod_client_id
# GITHUB_CLIENT_SECRET=prod_client_secret
# GITHUB_REDIRECT_URI=https://threagile.example.com/auth/callback
# GITHUB_ORG_URI=https://api.github.com/orgs/prod-org
# THREAGILE_DIRECTORY=/var/lib/threagile
# SESSION_TTL_SECONDS=28800
# COOKIE_SECURE=true
# COOKIE_SAMESITE=strict

# --- Local Storage Only (No GitHub) ---
# USING_LOCAL_STORAGE=true
# USING_GITHUB=false
# STORE_LOCAL_ENABLED=true
# ALLOWED_PATHS=/home/user/threat-models
# THREAGILE_DIRECTORY=/home/user/threagile
# SESSION_TTL_SECONDS=43200
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax

# --- GitHub Only (No Local Storage) ---
# USING_LOCAL_STORAGE=false
# USING_GITHUB=true
# STORE_GITHUB_ENABLED=true
# GITHUB_CLIENT_ID=client_id
# GITHUB_CLIENT_SECRET=client_secret
# GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback
# GITHUB_ORG_URI=https://api.github.com/orgs/my-org
# THREAGILE_DIRECTORY=/home/user/threagile
# SESSION_TTL_SECONDS=43200
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax

# --- Minimal (Browser Download Only) ---
# USING_LOCAL_STORAGE=false
# USING_GITHUB=false
# THREAGILE_DIRECTORY=/home/user/threagile
# SESSION_TTL_SECONDS=43200
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax
